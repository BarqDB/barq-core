// Version information
#cmakedefine BARQ_VERSION "@VERSION@"

// Feature detection
#cmakedefine01 BARQ_HAVE_READDIR64
#cmakedefine01 BARQ_HAVE_POSIX_FALLOCATE
#cmakedefine01 BARQ_USE_SYSTEM_OPENSSL_PATHS
#cmakedefine01 BARQ_HAVE_OPENSSL
#cmakedefine01 BARQ_HAVE_SECURE_TRANSPORT
#cmakedefine01 BARQ_HAVE_PTHREAD_GETNAME
#cmakedefine01 BARQ_HAVE_PTHREAD_SETNAME
#cmakedefine01 BARQ_HAVE_BACKTRACE
#cmakedefine01 BARQ_INCLUDE_CERTS
#define BARQ_MAX_BPNODE_SIZE @BARQ_MAX_BPNODE_SIZE@
#define BARQ_BACKTRACE_HEADER <@Backtrace_HEADER@>
#cmakedefine01 BARQ_ENABLE_ASSERTIONS
#cmakedefine01 BARQ_ENABLE_ALLOC_SET_ZERO
#cmakedefine01 BARQ_ENABLE_ENCRYPTION
#cmakedefine01 BARQ_ENABLE_MEMDEBUG
#cmakedefine01 BARQ_ENABLE_GEOSPATIAL
#cmakedefine01 BARQ_VALGRIND
#cmakedefine01 BARQ_ASAN
#cmakedefine01 BARQ_TSAN
